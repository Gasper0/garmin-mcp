# Copy this file to .env and fill in your Garmin Connect credentials.
# .env is gitignored and never committed.
#
# IMPORTANT: If you have two-factor authentication (2FA) enabled on your
# Garmin Connect account, you may need to temporarily disable it during
# the first authentication, then re-enable it after the session token
# has been cached (~/.garmin_mcp_tokens). See README.md "Troubleshooting".

GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password_here
